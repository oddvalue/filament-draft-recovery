{
    "name": "oddvalue/filament-draft-recovery",
    "description": "Auto-save draft & crash recovery for Filament create/edit pages, with swappable storage drivers (browser localStorage, database, or oddvalue/laravel-drafts)",
    "keywords": [
        "oddvalue",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "filament-draft-recovery",
        "drafts",
        "autosave"
    ],
    "homepage": "https://github.com/oddvalue/filament-draft-recovery",
    "support": {
        "issues": "https://github.com/oddvalue/filament-draft-recovery/issues",
        "source": "https://github.com/oddvalue/filament-draft-recovery"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "Jim",
            "email": "jim@oddvalue.co.uk",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^4.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "oddvalue/laravel-drafts": "^2.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.0"
    },
    "suggest": {
        "oddvalue/laravel-drafts": "Required to use the laravel-drafts storage driver (^2.0)"
    },
    "autoload": {
        "psr-4": {
            "Oddvalue\\FilamentDraftRecovery\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oddvalue\\FilamentDraftRecovery\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "lint": "pint",
        "refactor": "rector",
        "test": "pest",
        "test:coverage": "pest --coverage --min=100",
        "test:lint": "pint --test",
        "test:refactor": "rector --dry-run"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oddvalue\\FilamentDraftRecovery\\FilamentDraftRecoveryServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
