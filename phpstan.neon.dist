includes:
    - phpstan-baseline.neon

parameters:
    level: 4
    paths:
        - src
        - config
        - database
    tmpDir: build/phpstan
    ignoreErrors:
        # The trait is consumed by host applications, not by package code.
        - identifier: trait.unused
        # The laravel-drafts store works with arbitrary host models whose
        # HasDrafts methods only exist at runtime (asserted in
        # assertDraftableModel()).
        -
            identifier: method.notFound
            path: src/Stores/LaravelDraftsStore.php
        -
            identifier: staticMethod.notFound
            path: src/Stores/LaravelDraftsStore.php
        -
            identifier: property.notFound
            path: src/Stores/LaravelDraftsStore.php
        -
            identifier: varTag.unresolvableType
            path: src/Stores/LaravelDraftsStore.php
